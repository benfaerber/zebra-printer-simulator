# TCP listener for raw ZPL (Zebra default port is 9100)
TCP_HOST=
TCP_PORT=19100

# HTTP server for the web UI and API
HTTP_HOST=
HTTP_PORT=8081

# Directory where rendered labels are written
OUTPUT_DIR=./output

# Label size: 4x6, 6x4, or 2x4
LABEL_SIZE=4x6

# Printer resolution: 203, 300, or 600
DPI=203

# Optional basic auth for the HTTP server (both must be set, or both empty)
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# Cap on retained label files in OUTPUT_DIR (0 disables)
MAX_OUTPUT_FILES=0

# Optional webhook URL notified on each print
WEBHOOK_URL=
